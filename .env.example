# .env.example — NEXT_PUBLIC_* build-time inlines for Next.js
#
# Copy this file to `.env.local` (local dev) or `.env.production` (prod build)
# and fill in real values. Both files are gitignored.
#
# Next.js inlines any `NEXT_PUBLIC_*` variable it sees during `next build`
# into the client bundle. wrangler.jsonc `vars` is NOT a valid source for
# these — that's a Worker runtime binding, which never reaches the browser.
#
# Non-NEXT_PUBLIC_* secrets (ANTHROPIC_API_KEY, AI_GATEWAY_TOKEN, POSTHOG_API_KEY)
# live in `.dev.vars` (local) or `wrangler secret put` (prod) — see SETUP.md.

# PostHog — project API key (starts with `phc_`). From Project Settings → Project API Key.
# Write-only ingest key — safe to ship in the client bundle. Do NOT confuse with
# the server-side POSTHOG_API_KEY used for shutdown/flushing (that goes in secrets).
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingest host. Usually https://us.i.posthog.com (US cloud) or
# https://eu.i.posthog.com (EU cloud). Matches your PostHog project region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Turnstile site key — used by Phase 3 idea-submission form. Placeholder for now;
# leave blank until Phase 3 ships. (Create at dash.cloudflare.com → Turnstile.)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
